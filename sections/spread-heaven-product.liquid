{% comment %}
SPREAD HEAVEN PRODUCT DETAILS SECTION
Shopify Online Store 2.0 compatible section
{% endcomment %}

{% style %}
.sp-product {
  --sp-primary: {{ section.settings.primary_color }};
  --sp-primary-dark: {{ section.settings.primary_dark_color }};
  --sp-accent: {{ section.settings.accent_color }};
  --sp-bg: {{ section.settings.bg_color }};
  --sp-bg-card: #FFFDF9;
  --sp-text: {{ section.settings.text_color }};
  --sp-text-muted: {{ section.settings.text_muted_color }};
  --sp-text-light: #B89070;
  --sp-border: {{ section.settings.border_color }};
  --sp-white: #FFFFFF;
  --sp-success: #2E7D32;
  --sp-font-head: var(--font-heading-family);
  --sp-font-body: var(--font-body-family);
  --sp-radius: 12px;
  --sp-radius-sm: 8px;
  --sp-radius-lg: 20px;
  --sp-transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
  --sp-shadow-sm: 0 4px 16px {{ section.settings.primary_color | color_to_rgb: 0.05 }};
  --sp-shadow-md: 0 8px 30px {{ section.settings.primary_color | color_to_rgb: 0.08 }};
  --sp-shadow-lg: 0 20px 50px {{ section.settings.text_color | color_to_rgb: 0.12 }};
  position: relative;
  width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 12px 0 80px;
  background-color: var(--sp-bg);
  overflow: hidden;
}

.sp-product-inner {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
}

/* Breadcrumb */
.sp-breadcrumb-bar {
  padding: 14px 24px;
  background-color: var(--sp-bg-card);
  border-bottom: 1px solid var(--sp-border);
}
.sp-breadcrumb-inner {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--sp-text-light);
}
.sp-breadcrumb-inner a {
  color: var(--sp-text-light);
  transition: var(--sp-transition);
  text-decoration: none;
}
.sp-breadcrumb-inner a:hover {
  color: var(--sp-primary);
}
.sp-breadcrumb-inner i {
  font-size: 10px;
}
.sp-breadcrumb-inner span {
  color: var(--sp-primary);
}

/* Product Grid */
.sp-product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}

/* Gallery Column */
.sp-gallery-col {
  position: sticky;
  top: 96px;
}
.sp-gallery-main {
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-lg);
  overflow: hidden;
  background-color: var(--sp-bg-card);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--sp-shadow-md);
  position: relative;
  margin-bottom: 12px;
}
.sp-gallery-main img, .sp-gallery-main video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: opacity 0.3s ease;
}
.sp-gallery-main .sp-media-item {
  display: none;
  width: 100%;
  height: 100%;
}
.sp-gallery-main .sp-media-item.active {
  display: flex;
  align-items: center;
  justify-content: center;
}
.sp-gallery-main .sp-media-item img {
  object-fit: contain;
  padding: 20px;
}
.sp-gallery-main .sp-media-item video {
  object-fit: cover;
}
.sp-zoom-badge {
  position: absolute;
  bottom: 14px;
  right: 14px;
  background-color: rgba(255,249,243,0.92);
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-sm);
  padding: 6px 12px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--sp-text-muted);
  display: flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  transition: var(--sp-transition);
}
.sp-zoom-badge:hover {
  border-color: var(--sp-primary);
  color: var(--sp-primary);
}
.sp-gallery-thumbs {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 8px;
}
.sp-thumb-item {
  border: 2px solid var(--sp-border);
  border-radius: var(--sp-radius-sm);
  aspect-ratio: 1;
  overflow: hidden;
  cursor: pointer;
  transition: var(--sp-transition);
  background-color: var(--sp-bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.sp-thumb-item:hover {
  border-color: var(--sp-primary-dark);
}
.sp-thumb-item.active {
  border-color: var(--sp-primary);
  box-shadow: 0 0 0 2px {{ section.settings.primary_color | color_to_rgb: 0.2 }};
}
.sp-thumb-item img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 4px;
}

/* Info Column */
.sp-info-col {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

/* Brand / Tag */
.sp-prod-eyebrow {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.sp-brand-pill {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--sp-primary);
  background-color: {{ section.settings.primary_color | color_to_rgb: 0.08 }};
  padding: 5px 12px;
  border-radius: var(--sp-radius-sm);
}

/* Product Title */
.sp-prod-title-main {
  font-family: var(--sp-font-head);
  font-size: clamp(22px, 3.5vw, 40px);
  font-weight: 900;
  text-transform: uppercase;
  line-height: 1.1;
  color: var(--sp-text);
}
.sp-prod-title-main span {
  color: var(--sp-primary);
}

/* Rating & Stock Row */
.sp-rating-row {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}
.sp-stars {
  color: var(--sp-primary);
  display: flex;
  gap: 3px;
  font-size: 14px;
}
.sp-rating-score {
  font-size: 14px;
  font-weight: 700;
  color: var(--sp-text);
}
.sp-rating-count {
  font-size: 13px;
  color: var(--sp-text-light);
}
.sp-rating-divider {
  color: var(--sp-border);
}
.sp-in-stock-badge {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--sp-success);
  letter-spacing: 0.5px;
}
.sp-in-stock-badge::before {
  content: '';
  display: block;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background-color: var(--sp-success);
}

/* Price Block */
.sp-price-block {
  display: flex;
  align-items: baseline;
  gap: 12px;
  padding: 20px 0;
  border-top: 1px solid var(--sp-border);
  border-bottom: 1px solid var(--sp-border);
}
.sp-price-current {
  font-family: var(--sp-font-head);
  font-size: 36px;
  font-weight: 900;
  color: var(--sp-primary);
}
.sp-price-mrp {
  font-size: 18px;
  color: var(--sp-text-light);
  text-decoration: line-through;
  font-weight: 600;
}
.sp-price-savings {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  background-color: rgba(46,125,50,0.1);
  color: var(--sp-success);
  padding: 4px 10px;
  border-radius: var(--sp-radius-sm);
}
.sp-price-tax-note {
  font-size: 11px;
  color: var(--sp-text-light);
  display: block;
  margin-top: 4px;
}

/* Variant Picker */
.sp-picker-label {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--sp-text-muted);
  margin-bottom: 10px;
  display: flex;
  gap: 6px;
  align-items: center;
}
.sp-picker-label strong {
  color: var(--sp-text);
}
.sp-flavor-grid, .sp-weight-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.sp-variant-btn {
  border: 1.5px solid var(--sp-border);
  border-radius: var(--sp-radius-sm);
  padding: 8px 16px;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--sp-text-muted);
  transition: var(--sp-transition);
  cursor: pointer;
  background-color: var(--sp-bg-card);
}
.sp-variant-btn:hover {
  border-color: var(--sp-primary-dark);
  color: var(--sp-primary);
}
.sp-variant-btn.active {
  border-color: var(--sp-primary);
  color: var(--sp-primary);
  background-color: {{ section.settings.primary_color | color_to_rgb: 0.06 }};
}
.sp-weight-popular::after {
  content: 'Popular';
  position: absolute;
  top: -9px;
  right: 6px;
  font-size: 9px;
  font-weight: 800;
  text-transform: uppercase;
  background-color: var(--sp-primary);
  color: white;
  padding: 1px 6px;
  border-radius: 4px;
}

/* Quantity & Add to Cart */
.sp-qty-row {
  display: flex;
  align-items: center;
  gap: 0;
}
.sp-qty-btn {
  width: 42px;
  height: 42px;
  border: 1px solid var(--sp-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: var(--sp-text-muted);
  transition: var(--sp-transition);
  background-color: var(--sp-bg-card);
  cursor: pointer;
}
.sp-qty-btn:first-child {
  border-radius: var(--sp-radius-sm) 0 0 var(--sp-radius-sm);
}
.sp-qty-btn:last-child {
  border-radius: 0 var(--sp-radius-sm) var(--sp-radius-sm) 0;
}
.sp-qty-btn:hover {
  background-color: var(--sp-primary);
  color: white;
  border-color: var(--sp-primary);
}
.sp-qty-input {
  width: 56px;
  height: 42px;
  border: 1px solid var(--sp-border);
  border-left: none;
  border-right: none;
  text-align: center;
  font-family: var(--sp-font-head);
  font-size: 16px;
  font-weight: 700;
  color: var(--sp-text);
  background-color: var(--sp-bg-card);
  outline: none;
}
.sp-cta-row {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.sp-cta-sub-row {
  display: flex;
  gap: 12px;
}
.sp-cta-sub-row .sp-btn {
  flex: 1;
}
.sp-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 16px 28px;
  font-family: var(--sp-font-head);
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-sm);
  transition: var(--sp-transition);
  cursor: pointer;
  text-decoration: none;
}
.sp-btn-primary {
  background-color: var(--sp-primary);
  color: var(--sp-white);
  border-color: var(--sp-primary);
  box-shadow: 0 4px 20px {{ section.settings.primary_color | color_to_rgb: 0.35 }};
}
.sp-btn-primary:hover {
  background-color: var(--sp-primary-dark);
  border-color: var(--sp-primary-dark);
  transform: translateY(-2px);
  box-shadow: 0 8px 30px {{ section.settings.primary_color | color_to_rgb: 0.45 }};
}
.sp-btn-outline {
  background-color: transparent;
  color: var(--sp-primary);
  border-color: var(--sp-primary);
}
.sp-btn-outline:hover {
  background-color: {{ section.settings.primary_color | color_to_rgb: 0.08 }};
  transform: translateY(-2px);
}

/* Trust Strip */
.sp-trust-strip {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background-color: var(--sp-border);
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius);
  overflow: hidden;
}
.sp-trust-cell {
  background-color: var(--sp-bg-card);
  padding: 14px 12px;
  text-align: center;
}
.sp-trust-cell i {
  color: var(--sp-primary);
  font-size: 16px;
  margin-bottom: 5px;
  display: block;
}
.sp-trust-cell strong {
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  display: block;
  color: var(--sp-text);
}
.sp-trust-cell span {
  font-size: 10px;
  color: var(--sp-text-light);
}

/* Shipping Block */
.sp-shipping-block {
  background-color: var(--sp-bg-card);
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius);
  overflow: hidden;
}
.sp-shipping-row {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 18px;
  border-bottom: 1px solid var(--sp-border);
}
.sp-shipping-row:last-child {
  border-bottom: none;
}
.sp-shipping-row i {
  color: var(--sp-primary);
  width: 20px;
  font-size: 15px;
  flex-shrink: 0;
}
.sp-shipping-row-text strong {
  font-size: 13px;
  font-weight: 700;
  display: block;
  color: var(--sp-text);
}
.sp-shipping-row-text span {
  font-size: 12px;
  color: var(--sp-text-light);
}
.sp-pin-check {
  display: flex;
  gap: 0;
  margin-top: 8px;
}
.sp-pin-input {
  flex: 1;
  height: 40px;
  border: 1px solid var(--sp-border);
  border-right: none;
  border-radius: var(--sp-radius-sm) 0 0 var(--sp-radius-sm);
  padding: 0 14px;
  font-family: var(--sp-font-body);
  font-size: 13px;
  color: var(--sp-text);
  background-color: var(--sp-bg-card);
  outline: none;
  transition: var(--sp-transition);
}
.sp-pin-input:focus {
  border-color: var(--sp-primary);
}
.sp-pin-check-btn {
  height: 40px;
  padding: 0 18px;
  background-color: var(--sp-primary);
  color: white;
  border-radius: 0 var(--sp-radius-sm) var(--sp-radius-sm) 0;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  transition: var(--sp-transition);
  cursor: pointer;
  border: none;
}
.sp-pin-check-btn:hover {
  background-color: var(--sp-primary-dark);
}
.sp-pin-result {
  font-size: 12px;
  margin-top: 8px;
  color: var(--sp-success);
  display: none;
}
.sp-pin-result.show {
  display: block;
}

/* Loading spinner for sp-btn (mirrors Sense theme .button.loading behaviour) */
.sp-btn.loading {
  color: transparent;
  position: relative;
  pointer-events: none;
}
.sp-btn.loading > .loading__spinner {
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  position: absolute;
  height: 100%;
  display: flex;
  align-items: center;
}
.sp-btn.loading > .loading__spinner .spinner {
  animation: rotator 1.4s linear infinite;
  width: 20px;
  height: 20px;
}
.sp-btn.loading > .loading__spinner .path {
  stroke: white;
  stroke-dasharray: 187;
  stroke-dashoffset: 0;
  transform-origin: center;
  animation: dash 1.4s ease-in-out infinite;
}
@keyframes rotator {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(270deg); }
}
@keyframes dash {
  0% { stroke-dashoffset: 187; }
  50% { stroke-dashoffset: 46.75; transform: rotate(135deg); }
  100% { stroke-dashoffset: 187; transform: rotate(450deg); }
}
.loading__spinner.hidden { display: none !important; }

/* Error message */
.product-form__error-message-wrapper {
  background: #fff0f0;
  border: 1px solid #d32f2f;
  border-radius: var(--sp-radius-sm);
  padding: 12px 16px;
  margin-bottom: 12px;
  font-size: 13px;
  color: #d32f2f;
  display: flex;
  align-items: center;
  gap: 8px;
}
.product-form__error-message-wrapper[hidden] { display: none !important; }

{% endstyle %}

{% style %}
/* Tabs Section */
.sp-tabs-section {
  padding: 60px 0 0;
  border-top: 1px solid var(--sp-border);
  margin-top: 20px;
}
.sp-tab-nav {
  display: flex;
  gap: 0;
  border-bottom: 2px solid var(--sp-border);
  margin-bottom: 40px;
  overflow-x: auto;
}
.sp-tab-btn {
  padding: 14px 24px;
  font-family: var(--sp-font-head);
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--sp-text-muted);
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  transition: var(--sp-transition);
  white-space: nowrap;
  cursor: pointer;
  background: none;
  border-left: none;
  border-right: none;
  border-top: none;
}
.sp-tab-btn:hover {
  color: var(--sp-primary);
}
.sp-tab-btn.active {
  color: var(--sp-primary);
  border-bottom-color: var(--sp-primary);
}
.sp-tab-panel {
  display: none;
  animation: fadeInView 0.3s ease;
}
.sp-tab-panel.active {
  display: block;
}
@keyframes fadeInView {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Description Tab */
.sp-desc-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}
.sp-desc-body h3 {
  font-family: var(--sp-font-head);
  font-size: 22px;
  font-weight: 900;
  text-transform: uppercase;
  margin-bottom: 16px;
  color: var(--sp-text);
}
.sp-desc-body p {
  font-size: 15px;
  color: var(--sp-text-muted);
  line-height: 1.8;
  margin-bottom: 20px;
}
.sp-feature-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 24px;
}
.sp-feature-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  background-color: var(--sp-bg-card);
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius);
  padding: 14px;
}
.sp-feature-item i {
  color: var(--sp-primary);
  font-size: 14px;
  margin-top: 2px;
  flex-shrink: 0;
}
.sp-feature-item p {
  font-size: 13px;
  color: var(--sp-text-muted);
}
.sp-feature-item p strong {
  color: var(--sp-text);
}

/* Nutrition Tab */
.sp-nutrition-card {
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-lg);
  overflow: hidden;
  box-shadow: var(--sp-shadow-sm);
  max-width: 480px;
}
.sp-nutrition-header {
  background-color: var(--sp-primary);
  color: white;
  padding: 24px 28px;
}
.sp-nutrition-header h3 {
  font-family: var(--sp-font-head);
  font-size: 20px;
  font-weight: 900;
  text-transform: uppercase;
  margin-bottom: 4px;
}
.sp-nutrition-header p {
  font-size: 13px;
  opacity: 0.85;
}
.sp-nutrition-table {
  background-color: var(--sp-bg-card);
}
.sp-nutrition-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 13px 28px;
  border-bottom: 1px solid var(--sp-border);
  font-size: 14px;
}
.sp-nutrition-row:last-child {
  border-bottom: none;
}
.sp-nutrition-row.sp-bold {
  font-family: var(--sp-font-head);
  font-weight: 800;
  font-size: 15px;
}
.sp-nutrition-row .sp-val {
  font-weight: 700;
  color: var(--sp-primary);
}

/* Ingredients Tab */
.sp-ingredients-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 20px;
  margin-bottom: 40px;
}
.sp-ingredient-card {
  background-color: var(--sp-bg-card);
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-lg);
  padding: 24px 20px;
  text-align: center;
  transition: var(--sp-transition);
  box-shadow: var(--sp-shadow-sm);
}
.sp-ingredient-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--sp-shadow-md);
  border-color: var(--sp-primary);
}
.sp-ingredient-icon {
  font-size: 28px;
  margin-bottom: 12px;
}
.sp-ingredient-card h4 {
  font-family: var(--sp-font-head);
  font-size: 14px;
  font-weight: 800;
  text-transform: uppercase;
  margin-bottom: 6px;
  color: var(--sp-text);
}
.sp-ingredient-card p {
  font-size: 12px;
  color: var(--sp-text-muted);
  line-height: 1.5;
}
.sp-ingredients-full {
  background-color: var(--sp-bg-card);
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius);
  padding: 24px;
}
.sp-ingredients-full h4 {
  font-family: var(--sp-font-head);
  font-size: 14px;
  font-weight: 800;
  text-transform: uppercase;
  margin-bottom: 10px;
  color: var(--sp-text-muted);
}
.sp-ingredients-full p {
  font-size: 13px;
  color: var(--sp-text-muted);
  line-height: 1.8;
}
.sp-allergen-note {
  margin-top: 16px;
  padding: 12px 16px;
  background-color: {{ section.settings.primary_color | color_to_rgb: 0.06 }};
  border: 1px solid {{ section.settings.primary_color | color_to_rgb: 0.2 }};
  border-radius: var(--sp-radius-sm);
  font-size: 12px;
  color: var(--sp-text-muted);
}
.sp-allergen-note strong {
  color: var(--sp-primary);
}

/* Reviews Tab */
.sp-reviews-summary-bar {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 40px;
  align-items: center;
  background-color: var(--sp-bg-card);
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-lg);
  padding: 32px;
  margin-bottom: 40px;
  box-shadow: var(--sp-shadow-sm);
}
.sp-big-score {
  text-align: center;
  border-right: 1px solid var(--sp-border);
  padding-right: 40px;
}
.sp-big-score-num {
  font-family: var(--sp-font-head);
  font-size: 72px;
  font-weight: 900;
  color: var(--sp-primary);
  line-height: 1;
}
.sp-big-score-stars {
  color: var(--sp-primary);
  font-size: 18px;
  display: flex;
  justify-content: center;
  gap: 4px;
  margin: 8px 0;
}
.sp-big-score-count {
  font-size: 13px;
  color: var(--sp-text-light);
}
.sp-bar-breakdown {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.sp-bar-row {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 12px;
  font-weight: 700;
}
.sp-bar-row span:first-child {
  width: 40px;
  text-align: right;
  color: var(--sp-text-muted);
}
.sp-bar-row .sp-mini-bg {
  flex: 1;
  height: 8px;
  background-color: {{ section.settings.text_color | color_to_rgb: 0.1 }};
  border-radius: var(--sp-radius-sm);
  overflow: hidden;
}
.sp-bar-row .sp-mini-fill {
  height: 100%;
  background-color: var(--sp-primary);
  border-radius: var(--sp-radius-sm);
  transition: width 1s ease;
}
.sp-bar-row span:last-child {
  width: 30px;
  color: var(--sp-text-light);
}
.sp-reviews-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.sp-review-card {
  background-color: var(--sp-bg-card);
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-lg);
  padding: 28px;
  box-shadow: var(--sp-shadow-sm);
}
.sp-review-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 14px;
}
.sp-reviewer-info {
  display: flex;
  align-items: center;
  gap: 12px;
}
.sp-reviewer-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background-color: {{ section.settings.primary_color | color_to_rgb: 0.12 }};
  border: 1px solid var(--sp-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--sp-font-head);
  font-size: 16px;
  font-weight: 900;
  color: var(--sp-primary);
}
.sp-reviewer-name {
  font-size: 14px;
  font-weight: 700;
  color: var(--sp-text);
}
.sp-reviewer-meta {
  font-size: 11px;
  color: var(--sp-text-light);
  display: flex;
  gap: 8px;
}
.sp-verified-tag {
  color: var(--sp-success);
  font-weight: 600;
}
.sp-review-stars {
  color: var(--sp-primary);
  display: flex;
  gap: 3px;
  font-size: 13px;
}
.sp-review-title {
  font-family: var(--sp-font-head);
  font-size: 15px;
  font-weight: 800;
  text-transform: uppercase;
  margin-bottom: 8px;
  color: var(--sp-text);
}
.sp-review-text {
  font-size: 13px;
  color: var(--sp-text-muted);
  line-height: 1.7;
}
.sp-review-helpful {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 16px;
  font-size: 12px;
  color: var(--sp-text-light);
}
.sp-helpful-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-sm);
  padding: 4px 12px;
  font-size: 12px;
  font-weight: 600;
  color: var(--sp-text-muted);
  transition: var(--sp-transition);
  cursor: pointer;
}
.sp-helpful-btn:hover {
  border-color: var(--sp-primary);
  color: var(--sp-primary);
}

/* Related Products */
.sp-related-section {
  padding: 60px 24px;
  border-top: 1px solid var(--sp-border);
  max-width: 1280px;
  margin: 0 auto;
}
.sp-section-tag {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--sp-primary);
  display: block;
  margin-bottom: 8px;
}
.sp-section-title-sm {
  font-family: var(--sp-font-head);
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 900;
  text-transform: uppercase;
  margin-bottom: 32px;
  color: var(--sp-text);
}
.sp-related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 24px;
}
.sp-rel-card {
  background-color: var(--sp-bg-card);
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-lg);
  padding: 20px;
  box-shadow: var(--sp-shadow-sm);
  transition: var(--sp-transition);
  text-decoration: none;
}
.sp-rel-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--sp-shadow-lg);
  border-color: var(--sp-primary-dark);
}
.sp-rel-img {
  aspect-ratio: 1;
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius);
  overflow: hidden;
  background-color: var(--sp-white);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}
.sp-rel-img img {
  width: 85%;
  height: 85%;
  object-fit: contain;
}
.sp-rel-tag {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--sp-primary);
  margin-bottom: 4px;
}
.sp-rel-name {
  font-family: var(--sp-font-head);
  font-size: 15px;
  font-weight: 800;
  margin-bottom: 6px;
  line-height: 1.2;
  color: var(--sp-text);
}
.sp-rel-desc {
  font-size: 12px;
  color: var(--sp-text-muted);
  margin-bottom: 14px;
}
.sp-rel-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid var(--sp-border);
  padding-top: 12px;
}
.sp-rel-price {
  font-family: var(--sp-font-head);
  font-size: 17px;
  font-weight: 800;
  color: var(--sp-primary);
}
.sp-rel-btn {
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-sm);
  padding: 8px 16px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  transition: var(--sp-transition);
  color: var(--sp-text);
  cursor: pointer;
}
.sp-rel-btn:hover {
  background-color: var(--sp-primary);
  border-color: var(--sp-primary);
  color: white;
}

/* Ticker */
.sp-ticker-bar {
  background-color: var(--sp-primary-dark);
  color: var(--sp-white);
  padding: 18px 0;
  border-top: 1px solid var(--sp-border);
}
.sp-ticker-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  justify-content: space-around;
  align-items: center;
  flex-wrap: wrap;
  gap: 20px;
}
.sp-ticker-item {
  font-family: var(--sp-font-head);
  font-weight: 700;
  text-transform: uppercase;
  font-size: 13px;
  letter-spacing: 1px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.sp-ticker-item i {
  color: var(--sp-accent);
}

/* Responsive */
@media (max-width: 1024px) {
  .sp-product-grid { grid-template-columns: 1fr; gap: 40px; }
  .sp-gallery-col { position: static; }
  .sp-desc-split { grid-template-columns: 1fr; gap: 40px; }
  .sp-reviews-summary-bar { grid-template-columns: 1fr; }
  .sp-big-score { border-right: none; border-bottom: 1px solid var(--sp-border); padding-right: 0; padding-bottom: 24px; }
}
@media (max-width: 768px) {
  .sp-gallery-thumbs { grid-template-columns: repeat(6, 1fr); }
  .sp-trust-strip { grid-template-columns: 1fr; }
  .sp-cta-sub-row { flex-direction: column; }
  .sp-related-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .sp-related-grid { grid-template-columns: 1fr; }
  .sp-gallery-thumbs { grid-template-columns: repeat(6, 1fr); gap: 6px; }
}

/* Nutrition Bar Styles */
.sp-nutri-bar-wrap {
  margin-top: 32px;
}
.sp-nutri-bar-title {
  font-family: var(--sp-font-head);
  font-size: 22px;
  font-weight: 900;
  text-transform: uppercase;
  margin-bottom: 8px;
  color: var(--sp-text);
}
.sp-nutri-bar-item {
  margin-bottom: 20px;
}
.sp-nutri-bar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
  font-size: 13px;
  font-weight: 700;
}
.sp-nutri-bar-bg {
  width: 100%;
  height: 12px;
  background-color: {{ section.settings.text_color | color_to_rgb: 0.1 }};
  border-radius: var(--sp-radius-sm);
  overflow: hidden;
}
.sp-nutri-bar-fill {
  height: 100%;
  background-color: var(--sp-primary);
  border-radius: var(--sp-radius-sm);
  width: 0;
  transition: width 0.8s ease-out;
}

/* Shipping Tab Styles */
.sp-shipping-tab-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  margin-bottom: 32px;
}
.sp-shipping-tab-card {
  background-color: var(--sp-bg-card);
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-lg);
  padding: 28px 24px;
  box-shadow: var(--sp-shadow-sm);
}
.sp-shipping-tab-card i {
  font-size: 32px;
  color: var(--sp-primary);
  margin-bottom: 16px;
}
.sp-shipping-tab-card h4 {
  font-family: var(--sp-font-head);
  font-size: 16px;
  font-weight: 800;
  text-transform: uppercase;
  margin-bottom: 12px;
  color: var(--sp-text);
}
.sp-shipping-tab-card p {
  font-size: 13px;
  color: var(--sp-text-muted);
  line-height: 1.6;
  margin-bottom: 12px;
}
.sp-tag {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--sp-white);
  background-color: var(--sp-primary);
  padding: 4px 10px;
  border-radius: var(--sp-radius-sm);
}
.sp-return-policy {
  background-color: var(--sp-bg-card);
  border: 1px solid var(--sp-border);
  border-radius: var(--sp-radius-lg);
  padding: 28px;
  box-shadow: var(--sp-shadow-sm);
}
.sp-return-policy h3 {
  font-family: var(--sp-font-head);
  font-size: 18px;
  font-weight: 900;
  text-transform: uppercase;
  margin-bottom: 20px;
  color: var(--sp-text);
}
.sp-policy-row {
  display: flex;
  gap: 16px;
  padding: 16px 0;
  border-bottom: 1px solid var(--sp-border);
}
.sp-policy-row:last-child {
  border-bottom: none;
}
.sp-policy-row i {
  font-size: 20px;
  color: var(--sp-primary);
  margin-top: 2px;
  flex-shrink: 0;
}
.sp-policy-row strong {
  font-size: 13px;
  font-weight: 700;
  display: block;
  color: var(--sp-text);
  margin-bottom: 4px;
}
.sp-policy-row p {
  font-size: 13px;
  color: var(--sp-text-muted);
  line-height: 1.6;
  margin: 0;
}
{% endstyle %}

<!-- Breadcrumb -->
<div class="sp-breadcrumb-bar">
  <div class="sp-breadcrumb-inner">
    <a href="{{ routes.root_url }}">Home</a>
    <i class="fa-solid fa-chevron-right"></i>
    <a href="{{ routes.collections_url }}">Shop</a>
    <i class="fa-solid fa-chevron-right"></i>
    {% if collection %}
      <a href="{{ collection.url }}">{{ collection.title | escape }}</a>
      <i class="fa-solid fa-chevron-right"></i>
    {% endif %}
    <span>{{ product.title | escape }}</span>
  </div>
</div>

<!-- Main Product Section -->
<section class="sp-product">
  <div class="sp-product-inner">
    <div class="sp-product-grid">
      
      <!-- Gallery Column -->
      <div class="sp-gallery-col">
        <div class="sp-gallery-main" id="spMainMedia">
          {% for media in product.media %}
            <div class="sp-media-item {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
              {% if media.media_type == 'image' %}
                <img 
                  src="{{ media | image_url: width: 1000 }}" 
                  alt="{{ media.alt | escape | default: product.title | escape }}"
                  id="spMainImage{{ forloop.index0 }}"
                >
              {% elsif media.media_type == 'video' %}
                <video 
                  controls 
                  muted 
                  loop 
                  playsinline 
                  id="spProductVideo{{ forloop.index0 }}"
                  style="width:100%;height:100%;object-fit:cover;"
                >
                  <source src="{{ media | media_source_url: 1000 }}" type="video/mp4">
                </video>
              {% endif %}
            </div>
          {% endfor %}
          {% if product.images.size == 0 %}
            <div class="sp-media-item active" data-index="0">
              <img src="https://images.unsplash.com/photo-1626200419199-391ae4be7a41?w=700&q=85" alt="Product Image">
            </div>
          {% endif %}
          <div class="sp-zoom-badge" id="spZoomBadge">
            <i class="fa-solid fa-magnifying-glass-plus"></i> Zoom
          </div>
        </div>

        <!-- Thumbnails -->
        {% if product.media.size > 1 %}
          <div class="sp-gallery-thumbs">
            {% for media in product.media %}
              <div class="sp-thumb-item {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
                {% if media.media_type == 'image' %}
                  <img 
                    src="{{ media | image_url: width: 120 }}" 
                    alt="{{ media.alt | escape | default: product.title | escape }}"
                  >
                {% else %}
                  <div class="sp-thumb-item video-thumb">
                    <i class="fa-solid fa-film"></i>
                  </div>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Info Column -->
      <div class="sp-info-col">
        
        <!-- Eyebrow -->
        <div class="sp-prod-eyebrow">
          {% if section.settings.show_new_badge %}
            <span class="sp-brand-pill" style="background-color:{{ section.settings.success_color }}; color:white;">New</span>
          {% endif %}
        </div>

        <!-- Title -->
        <h1 class="sp-prod-title-main">{{ product.title | escape }}</h1>

        <!-- Rating & Stock -->
        <div class="sp-rating-row">
          {% if product.metafields.spread_heaven.rating %}
            <div class="sp-stars" aria-label="{{ product.metafields.spread_heaven.rating }} out of 5 stars">
              {% for i in (1..5) %}
                {% if i <= product.metafields.spread_heaven.rating %}
                  <i class="fa-solid fa-star"></i>
                {% else %}
                  <i class="fa-regular fa-star"></i>
                {% endif %}
              {% endfor %}
            </div>
            <div class="sp-rating-score">{{ product.metafields.spread_heaven.rating }}</div>
            {% if product.metafields.spread_heaven.review_count %}
              <div class="sp-rating-divider">•</div>
              <div class="sp-rating-count">{{ product.metafields.spread_heaven.review_count }} reviews</div>
            {% endif %}
          {% endif %}
          {% if product.available %}
            <div class="sp-in-stock-badge">In stock</div>
          {% else %}
            <div class="sp-in-stock-badge" style="color:#d32f2f;">Out of stock</div>
          {% endif %}
        </div>

        <!-- Price -->
        <div class="sp-price-block">
          <div>
            {% if product.compare_at_price > product.price %}
              <span class="sp-price-mrp">{{ product.compare_at_price | money }}</span>
              <span class="sp-price-current">{{ product.price | money }}</span>
              {% assign savings = product.compare_at_price | minus: product.price %}
              {% assign savings_percent = savings | times: 100 | divided_by: product.compare_at_price %}
              <span class="sp-price-savings">Save {{ savings_percent }}%</span>
            {% else %}
              <span class="sp-price-current">{{ product.price | money }}</span>
            {% endif %}
            {% if section.settings.show_tax_shipping_note %}
              <span class="sp-price-tax-note">Tax included. Shipping calculated at checkout.</span>
            {% endif %}
          </div>
        </div>

        <!-- Variant Pickers -->
        <product-form id="spProductForm" data-productid="{{ product.id }}">
          {% form 'product', product, id: 'spAddToCartForm' %}
            <!-- Variant JSON Data -->
            <script type="application/json" id="spVariantJson">
              {{ product.variants | json }}
            </script>
            <input type="hidden" name="id" id="spVariantId" value="{{ product.selected_or_first_available_variant.id }}">
            
            {% unless product.has_only_default_variant %}
              {% for option in product.options_with_values %}
                <div class="sp-picker-section" style="margin-bottom:20px;">
                  <div class="sp-picker-label">
                    <strong>{{ option.name | escape }}</strong>
                  </div>
                  {% assign option_index = forloop.index0 %}
                  {% if option.name == 'Size' or option.name == 'size' or option.name == 'Weight' or option.name == 'weight' %}
                    <div class="sp-weight-grid" data-option="{{ option_index }}">
                      {% for value in option.values %}
                        <button 
                          type="button"
                          class="sp-variant-btn {% if forloop.first %}active{% endif %}"
                          data-value="{{ value | escape }}"
                          {% if forloop.first %}data-popular="true"{% endif %}
                          onclick="selectVariantOption(this, {{ option_index }}, '{{ value | escape }}')"
                        >
                          {{ value | escape }}
                        </button>
                      {% endfor %}
                    </div>
                  {% else %}
                    <div class="sp-flavor-grid" data-option="{{ option_index }}">
                      {% for value in option.values %}
                        <button 
                          type="button"
                          class="sp-variant-btn {% if forloop.first %}active{% endif %}"
                          data-value="{{ value | escape }}"
                          onclick="selectVariantOption(this, {{ option_index }}, '{{ value | escape }}')"
                        >
                          {{ value | escape }}
                        </button>
                      {% endfor %}
                    </div>
                  {% endif %}
                </div>
              {% endfor %}
            {% endunless %}

            <!-- Quantity -->
            <div style="margin-bottom:20px;">
              <div class="sp-picker-label"><strong>Quantity</strong></div>
              <div class="sp-qty-row">
                <button class="sp-qty-btn" type="button" id="spQtyMinus"><i class="fa-solid fa-minus"></i></button>
                <input class="sp-qty-input" id="spQtyInput" type="number" name="quantity" value="1" min="1">
                <button class="sp-qty-btn" type="button" id="spQtyPlus"><i class="fa-solid fa-plus"></i></button>
              </div>
            </div>

            <!-- Add to Cart -->
            <div class="sp-cta-row">
              <div class="sp-cta-sub-row">
                <button type="submit" class="sp-btn sp-btn-primary" name="add" id="spAddToCartBtn" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
                  <i class="fa-solid fa-shopping-bag"></i>
                  <span>Add to Cart</span>
                  <div class="loading__spinner hidden">
                    <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg" width="18" height="18">
                      <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                    </svg>
                  </div>
                </button>
                <button type="button" class="sp-btn sp-btn-outline" id="spBuyNowBtn" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
                  <i class="fa-solid fa-bolt"></i> Buy Now
                </button>
              </div>
            </div>
            <!-- Error Message Wrapper (required by product-form.js) -->
            <div class="product-form__error-message-wrapper" role="alert" hidden>
              <i class="fa-solid fa-circle-exclamation"></i>
              <span class="product-form__error-message"></span>
            </div>
          {% endform %}
        </product-form>

        <!-- Trust Strip -->
        <div class="sp-trust-strip">
          <div class="sp-trust-cell">
            <i class="fa-solid fa-truck-fast"></i>
            <strong>{{ section.settings.trust1_title | escape }}</strong>
            <span>{{ section.settings.trust1_desc | escape }}</span>
          </div>
          <div class="sp-trust-cell">
            <i class="fa-solid fa-shield-halved"></i>
            <strong>{{ section.settings.trust2_title | escape }}</strong>
            <span>{{ section.settings.trust2_desc | escape }}</span>
          </div>
        </div>

        <!-- Shipping Block -->
        <div class="sp-shipping-block">
          <div class="sp-shipping-row">
            <i class="fa-solid fa-truck"></i>
            <div class="sp-shipping-row-text">
              <strong>Free Shipping</strong>
              <span>On all orders across India</span>
            </div>
          </div>
          <div class="sp-shipping-row" style="display:block;">
            <div style="display:flex; gap:12px; align-items:center;">
              <i class="fa-solid fa-location-dot"></i>
              <div class="sp-shipping-row-text" style="flex:1;">
                <strong>Check Delivery</strong>
                <span>Enter your pincode for delivery date</span>
              </div>
            </div>
            <div class="sp-pin-check">
              <input type="text" class="sp-pin-input" id="spPinInput" placeholder="Enter pincode">
              <button class="sp-pin-check-btn" type="button" id="spPinCheckBtn">Check</button>
            </div>
            <div class="sp-pin-result" id="spPinResult">✅ Estimated delivery: 3-5 days</div>
          </div>
        </div>

      </div>
    </div>

    <!-- Tabs -->
    <div class="sp-tabs-section">
      <div class="sp-tab-nav" id="spTabNav">
        <button class="sp-tab-btn active" data-tab="description" type="button">Description</button>
        <button class="sp-tab-btn" data-tab="nutrition" type="button">Nutrition</button>
        <button class="sp-tab-btn" data-tab="ingredients" type="button">Ingredients</button>
        <button class="sp-tab-btn" data-tab="shipping" type="button">Shipping</button>
