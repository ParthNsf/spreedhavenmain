<script>
document.addEventListener('DOMContentLoaded', function () {

  /* ── Variant state ─────────────────────────────────────────── */
  var variantData = null;
  var selectedOptions = [];

  var variantJsonEl = document.getElementById('spVariantJson');
  if (variantJsonEl) {
    try { variantData = JSON.parse(variantJsonEl.textContent); } catch(e) {}
  }

  // Initialise selectedOptions from the first active button in each picker group
  document.querySelectorAll('[data-option]').forEach(function (grid) {
    var idx = parseInt(grid.dataset.option, 10);
    var firstActive = grid.querySelector('.sp-variant-btn.active');
    selectedOptions[idx] = firstActive ? firstActive.dataset.value : '';
  });

  /* ── selectVariantOption ────────────────────────────────────── */
  window.selectVariantOption = function (btn, optionIndex, value) {
    // Update active state for this option group
    var grid = btn.closest('[data-option]');
    if (grid) {
      grid.querySelectorAll('.sp-variant-btn').forEach(function (b) { b.classList.remove('active'); });
    }
    btn.classList.add('active');
    selectedOptions[optionIndex] = value;

    // Find matching variant
    var matched = null;
    if (variantData) {
      matched = variantData.find(function (v) {
        return v.options.every(function (opt, i) {
          return selectedOptions[i] === undefined || selectedOptions[i] === '' || opt === selectedOptions[i];
        });
      });
    }

    var variantInput = document.getElementById('spVariantId');
    var addBtn       = document.getElementById('spAddToCartBtn');
    var buyNowBtn    = document.getElementById('spBuyNowBtn');
    var priceEl      = document.querySelector('.sp-price-current');
    var mrpEl        = document.querySelector('.sp-price-mrp');
    var savingsEl    = document.querySelector('.sp-price-savings');
    var stockEl      = document.querySelector('.sp-in-stock-badge');

    if (matched) {
      if (variantInput) variantInput.value = matched.id;

      // Update price display
      if (priceEl) {
        var formatter = new Intl.NumberFormat(document.documentElement.lang || 'en', { style: 'currency', currency: window.Shopify && window.Shopify.currency ? window.Shopify.currency.active : 'INR', minimumFractionDigits: 0 });
        priceEl.textContent = window.Shopify && window.Shopify.formatMoney ? Shopify.formatMoney(matched.price) : (matched.price / 100).toFixed(2);
        if (mrpEl && matched.compare_at_price && matched.compare_at_price > matched.price) {
          mrpEl.style.display = '';
          mrpEl.textContent = window.Shopify && window.Shopify.formatMoney ? Shopify.formatMoney(matched.compare_at_price) : (matched.compare_at_price / 100).toFixed(2);
          if (savingsEl) {
            var pct = Math.round((matched.compare_at_price - matched.price) * 100 / matched.compare_at_price);
            savingsEl.textContent = 'Save ' + pct + '%';
            savingsEl.style.display = '';
          }
        } else {
          if (mrpEl) mrpEl.style.display = 'none';
          if (savingsEl) savingsEl.style.display = 'none';
        }
      }

      // Update availability
      var available = matched.available;
      if (addBtn)    { addBtn.disabled    = !available; }
      if (buyNowBtn) { buyNowBtn.disabled = !available; }
      if (stockEl) {
        stockEl.textContent = available ? 'In stock' : 'Out of stock';
        stockEl.style.color = available ? '' : '#d32f2f';
      }
    }
  };

  /* ── Quantity controls ──────────────────────────────────────── */
  var qtyInput = document.getElementById('spQtyInput');
  var qtyMinus = document.getElementById('spQtyMinus');
  var qtyPlus  = document.getElementById('spQtyPlus');

  if (qtyMinus && qtyInput) {
    qtyMinus.addEventListener('click', function () {
      var v = parseInt(qtyInput.value, 10) || 1;
      if (v > 1) qtyInput.value = v - 1;
    });
  }
  if (qtyPlus && qtyInput) {
    qtyPlus.addEventListener('click', function () {
      var v = parseInt(qtyInput.value, 10) || 1;
      qtyInput.value = v + 1;
    });
  }

  /* ── Buy Now ────────────────────────────────────────────────── */
  var buyNowBtn = document.getElementById('spBuyNowBtn');
  if (buyNowBtn) {
    buyNowBtn.addEventListener('click', function () {
      var variantId = document.getElementById('spVariantId') ? document.getElementById('spVariantId').value : '';
      var qty = qtyInput ? (parseInt(qtyInput.value, 10) || 1) : 1;
      if (!variantId) return;

      buyNowBtn.disabled = true;
      buyNowBtn.textContent = 'Processing...';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId, 10), quantity: qty })
      })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.status) {
          alert(data.description || data.message || 'Could not add to cart.');
          buyNowBtn.disabled = false;
          buyNowBtn.innerHTML = '<i class="fa-solid fa-bolt"></i> Buy Now';
        } else {
          window.location.href = '/checkout';
        }
      })
      .catch(function () {
        buyNowBtn.disabled = false;
        buyNowBtn.innerHTML = '<i class="fa-solid fa-bolt"></i> Buy Now';
      });
    });
  }

  /* ── Gallery thumbnails ─────────────────────────────────────── */
  document.querySelectorAll('.sp-thumb-item').forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      var idx = this.dataset.index;
      document.querySelectorAll('.sp-thumb-item').forEach(function (t) { t.classList.remove('active'); });
      document.querySelectorAll('.sp-media-item').forEach(function (m) { m.classList.remove('active'); });
      this.classList.add('active');
      var target = document.querySelector('.sp-media-item[data-index="' + idx + '"]');
      if (target) target.classList.add('active');
    });
  });

  /* ── Tabs ───────────────────────────────────────────────────── */
  document.querySelectorAll('.sp-tab-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var tab = this.dataset.tab;
      document.querySelectorAll('.sp-tab-btn').forEach(function (b) { b.classList.remove('active'); });
      document.querySelectorAll('.sp-tab-panel').forEach(function (p) { p.classList.remove('active'); });
      this.classList.add('active');
      var panel = document.getElementById('spTab-' + tab);
      if (panel) panel.classList.add('active');
    });
  });

  /* ── Pincode check ──────────────────────────────────────────── */
  var pinBtn = document.getElementById('spPinCheckBtn');
  var pinInput = document.getElementById('spPinInput');
  var pinResult = document.getElementById('spPinResult');
  if (pinBtn && pinInput && pinResult) {
    pinBtn.addEventListener('click', function () {
      var pin = pinInput.value.trim();
      if (pin.length === 6 && /^\d+$/.test(pin)) {
        pinResult.textContent = '✅ Estimated delivery: 3–5 business days';
        pinResult.classList.add('show');
      } else {
        pinResult.textContent = '❌ Please enter a valid 6-digit pincode.';
        pinResult.style.color = '#d32f2f';
        pinResult.classList.add('show');
      }
    });
  }

  /* ── Animate nutrition bars on scroll ──────────────────────── */
  function animateBars() {
    document.querySelectorAll('.sp-nutri-bar-fill, .sp-mini-fill').forEach(function (el) {
      el.style.width = el.dataset.width || '0%';
    });
  }
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) { if (e.isIntersecting) { animateBars(); observer.disconnect(); } });
  }, { threshold: 0.1 });
  var tabsSection = document.querySelector('.sp-tabs-section');
  if (tabsSection) observer.observe(tabsSection);

});
</script>

