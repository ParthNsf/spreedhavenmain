{% comment %}
SPREAD HEAVEN ABOUT US SECTION
Shopify Online Store 2.0 compatible section
{% endcomment %}

{% style %}
.sp-about {
  --sp-primary: {{ section.settings.primary_color }};
  --sp-primary-dark: {{ section.settings.primary_dark_color }};
  --sp-accent: {{ section.settings.accent_color }};
  --sp-bg: {{ section.settings.bg_color }};
  --sp-bg-card: #FFFDF9;
  --sp-text: {{ section.settings.text_color }};
  --sp-text-muted: {{ section.settings.text_muted_color }};
  --sp-text-light: #B89070;
  --sp-border: {{ section.settings.border_color }};
  --sp-radius-sm: 8px;
  --sp-radius-md: 16px;
  --sp-radius-lg: 24px;
  --sp-radius-xl: 40px;
  --sp-transition: 0.3s cubic-bezier(0.4,0,0.2,1);
  --sp-font-head: var(--font-heading-family);
  --sp-font-body: var(--font-body-family);
  --sp-shadow-sm: 0 2px 12px {{ section.settings.primary_color | color_to_rgb: 0.10 }};
  --sp-shadow-md: 0 8px 32px {{ section.settings.primary_color | color_to_rgb: 0.15 }};
  --sp-shadow-lg: 0 24px 64px {{ section.settings.primary_color | color_to_rgb: 0.20 }};
  position: relative;
  width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 76px 0 40px;
  background-color: var(--sp-bg);
  overflow: hidden;
}

.sp-about::before {
  content: '';
  position: absolute;
  top: -200px;
  right: -200px;
  width: 700px;
  height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, {{ section.settings.primary_color | color_to_rgb: 0.12 }} 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.sp-about-inner {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: 44px 24px;
}

.sp-section-header {
  text-align: center;
  max-width: 800px;
  margin: 0 auto 48px;
}

.sp-section-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--sp-primary);
  background-color: {{ section.settings.primary_color | color_to_rgb: 0.08 }};
  padding: 6px 14px;
  border-radius: var(--sp-radius-xl);
  margin-bottom: 16px;
}

.sp-section-title {
  font-family: var(--sp-font-head);
  font-size: clamp(32px, 4.5vw, 56px);
  font-weight: 900;
  line-height: 1.1;
  color: var(--sp-text);
  margin-bottom: 16px;
}

.sp-section-description {
  font-size: 16px;
  color: var(--sp-text-muted);
  line-height: 1.7;
}

.sp-about-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  margin: 48px 0;
}

.sp-about-card {
  background: var(--sp-bg-card);
  padding: 32px 24px;
  border-radius: var(--sp-radius-lg);
  border: 1px solid var(--sp-border);
  text-align: center;
  transition: var(--sp-transition);
}

.sp-about-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--sp-shadow-md);
  border-color: var(--sp-accent);
}

.sp-about-icon {
  width: 64px;
  height: 64px;
  margin: 0 auto 16px;
  background: linear-gradient(135deg, var(--sp-primary), var(--sp-accent));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  color: #fff;
}

.sp-about-card h3 {
  margin-bottom: 12px;
  color: var(--sp-text);
  font-family: var(--sp-font-head);
}

.sp-about-card p {
  color: var(--sp-text-muted);
  font-size: 14px;
  line-height: 1.6;
}

.sp-about-story {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
  margin: 60px 0;
}

.sp-story-text p {
  color: var(--sp-text-muted);
  line-height: 1.7;
  margin-bottom: 16px;
  font-size: 15px;
}

.sp-story-image-frame {
  aspect-ratio: 4/3;
  border-radius: var(--sp-radius-lg);
  overflow: hidden;
  border: 1px solid var(--sp-border);
  box-shadow: var(--sp-shadow-md);
}

.sp-story-image-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.sp-milestones {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 24px;
  margin-top: 48px;
}

.sp-milestone {
  text-align: center;
  padding: 24px 16px;
  background: var(--sp-bg-card);
  border-radius: var(--sp-radius-md);
  border: 1px solid var(--sp-border);
}

.sp-milestone-number {
  font-size: 48px;
  font-weight: 800;
  color: var(--sp-primary);
  margin-bottom: 4px;
  font-family: var(--sp-font-head);
}

.sp-milestone-label {
  font-size: 12px;
  color: var(--sp-text-light);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-weight: 600;
}

@media (max-width: 900px) {
  .sp-about-story {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 600px) {
  .sp-about-inner {
    padding: 24px 16px;
  }

  .sp-about-grid {
    grid-template-columns: 1fr;
  }
}
{% endstyle %}

<section class="sp-about">
  <div class="sp-about-inner">
    <div class="sp-section-header">
      <div class="sp-section-eyebrow">{{ section.settings.eyebrow_text | escape }}</div>
      <h2 class="sp-section-title">{{ section.settings.heading | escape }}</h2>
      <p class="sp-section-description">{{ section.settings.description | escape }}</p>
    </div>

    <div class="sp-about-grid">
      {% if section.settings.card_1_title != blank %}
        <div class="sp-about-card">
          <div class="sp-about-icon">{{ section.settings.card_1_icon | escape }}</div>
          <h3>{{ section.settings.card_1_title | escape }}</h3>
          <p>{{ section.settings.card_1_description | escape }}</p>
        </div>
      {% endif %}
      {% if section.settings.card_2_title != blank %}
        <div class="sp-about-card">
          <div class="sp-about-icon">{{ section.settings.card_2_icon | escape }}</div>
          <h3>{{ section.settings.card_2_title | escape }}</h3>
          <p>{{ section.settings.card_2_description | escape }}</p>
        </div>
      {% endif %}
      {% if section.settings.card_3_title != blank %}
        <div class="sp-about-card">
          <div class="sp-about-icon">{{ section.settings.card_3_icon | escape }}</div>
          <h3>{{ section.settings.card_3_title | escape }}</h3>
          <p>{{ section.settings.card_3_description | escape }}</p>
        </div>
      {% endif %}
    </div>

    {% if section.settings.story_title != blank %}
      <div class="sp-about-story">
        <div class="sp-story-image-frame">
          {% if section.settings.story_image != blank %}
            {{
              section.settings.story_image
              | image_url: width: 1000
              | image_tag:
                loading: 'lazy',
                alt: section.settings.story_image_alt | default: 'Our Story'
            }}
          {% else %}
            <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--sp-accent),var(--sp-bg));display:flex;align-items:center;justify-content:center;font-size:80px;">📖</div>
          {% endif %}
        </div>
        <div class="sp-story-text">
          <h3 style="font-family: var(--sp-font-head); color: var(--sp-text); margin-bottom: 16px;">{{ section.settings.story_title | escape }}</h3>
          <p>{{ section.settings.story_description_1 | escape }}</p>
          <p>{{ section.settings.story_description_2 | escape }}</p>
        </div>
      </div>
    {% endif %}

    {% if section.settings.milestone_1_value != blank or section.settings.milestone_2_value != blank or section.settings.milestone_3_value != blank or section.settings.milestone_4_value != blank %}
      <div class="sp-milestones">
        {% if section.settings.milestone_1_value != blank %}
          <div class="sp-milestone">
            <div class="sp-milestone-number">{{ section.settings.milestone_1_value | escape }}</div>
            <div class="sp-milestone-label">{{ section.settings.milestone_1_label | escape }}</div>
          </div>
        {% endif %}
        {% if section.settings.milestone_2_value != blank %}
          <div class="sp-milestone">
            <div class="sp-milestone-number">{{ section.settings.milestone_2_value | escape }}</div>
            <div class="sp-milestone-label">{{ section.settings.milestone_2_label | escape }}</div>
          </div>
        {% endif %}
        {% if section.settings.milestone_3_value != blank %}
          <div class="sp-milestone">
            <div class="sp-milestone-number">{{ section.settings.milestone_3_value | escape }}</div>
            <div class="sp-milestone-label">{{ section.settings.milestone_3_label | escape }}</div>
          </div>
        {% endif %}
        {% if section.settings.milestone_4_value != blank %}
          <div class="sp-milestone">
            <div class="sp-milestone-number">{{ section.settings.milestone_4_value | escape }}</div>
            <div class="sp-milestone-label">{{ section.settings.milestone_4_label | escape }}</div>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

