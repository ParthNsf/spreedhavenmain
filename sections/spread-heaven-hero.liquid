      "default": "#B97734"
    },
    {
      "type": "color",
      "id": "primary_dark_color",
      "label": "Primary Dark Color",
      "default": "#8A5A2B"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#E7C18C"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFF9F3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#2B1B0F"
    },
    {
      "type": "color",
      "id": "text_muted_color",
