      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary Button Label",
      "default": "Discover Flavors"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "header",
      "content": "Metrics"
    },
    {
      "type": "text",
      "id": "metric_1_value",
      "label": "Metric 1 Value",
      "default": "Up to 27g"
    },
    {
      "type": "text",
      "id": "metric_1_label",
      "label": "Metric 1 Label",
      "default": "Protein / 100g"
    },
    {
      "type": "text",
      "id": "metric_2_value",
