          "label": "Card Description",
          "default": "Roasted slowly in custom batches to lock in core minerals, natural heart-healthy fats, and deep toasted nut flavor profiles."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Spread Heaven",
      "category": "Text",
      "blocks": [
        {
          "type": "why_card",
          "settings": {
            "icon": "fa-solid fa-seedling",
