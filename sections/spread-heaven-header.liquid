{% comment %}
Spread Heaven Header - Exact replica of the original HTML header
{% endcomment %}

{% style %}
.sp-header-wrapper {
  --sp-primary: {{ section.settings.primary_color | default: "#B97734" }};
  --sp-primary-dark: {{ section.settings.primary_dark_color | default: "#8A5A2B" }};
  --sp-accent: {{ section.settings.accent_color | default: "#E7C18C" }};
  --sp-bg: {{ section.settings.bg_color | default: "#FFF9F3" }};
  --sp-bg-glass: rgba(255, 249, 243, 0.85);
  --sp-text: {{ section.settings.text_color | default: "#2B1B0F" }};
  --sp-text-muted: {{ section.settings.text_muted_color | default: "#5D4330" }};
  --sp-border: {{ section.settings.border_color | default: "#EBDCCB" }};
  --sp-radius: 12px;
  --sp-radius-sm: 8px;
  --sp-radius-lg: 20px;
  --sp-transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --sp-shadow-sm: 0 4px 16px rgba(138, 90, 43, 0.05);
  --sp-font-head: var(--font-heading-family, 'Poppins', sans-serif);
  --sp-font-body: var(--font-body-family, 'Inter', sans-serif);
  --sp-scroll-progress: 0%;
  --sp-logo-max-width: {{ section.settings.brand_logo_max_width | default: 35 }}px;
  --sp-logo-max-height: {{ section.settings.brand_logo_max_height | default: 35 }}px;
}

.sp-scroll-progress {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 3px;
  z-index: 9999; /* Very high z-index for scroll bar */
}
.sp-scroll-progress-fill {
  height: 100%;
  background: var(--sp-primary);
  width: var(--sp-scroll-progress);
  transition: width 0.1s ease-out;
}

.sp-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 76px;
  background: var(--sp-bg-glass);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--sp-border);
  z-index: 9998; /* Very high z-index for navbar */
  display: flex;
  align-items: center;
  transition: var(--sp-transition);
}
.sp-navbar.scrolled {
  border-bottom-color: var(--sp-border);
  box-shadow: var(--sp-shadow-sm);
}
.sp-nav-container {
  max-width: 1280px;
  width: 100%;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.sp-logo {
  font-family: var(--sp-font-head);
  font-weight: 800;
  font-size: 20px;
  color: var(--sp-primary);
  letter-spacing: 1px;
  text-decoration: none;
  line-height: 1;
  display: flex;
  align-items: center;
}
.sp-logo span {
  color: var(--sp-text);
}
.sp-logo-img {
  max-width: var(--sp-logo-max-width) !important;
  max-height: var(--sp-logo-max-height) !important;
  width: auto !important;
  height: auto !important;
}

.sp-nav-links {
  display: flex;
  align-items: center;
  gap: 8px;
}
.sp-nav-link {
  font-size: 14px;
  font-weight: 500;
  color: var(--sp-text-muted);
  padding: 8px 14px;
  border-radius: var(--sp-radius-sm);
  text-decoration: none;
  transition: all var(--sp-transition);
}
.sp-nav-link:hover, .sp-nav-link.active {
  color: var(--sp-primary);
  background: rgba(185, 119, 52, 0.08);
}

.sp-nav-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}
.sp-nav-btn {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--sp-radius-sm);
  color: var(--sp-text-muted);
  transition: all var(--sp-transition);
  font-size: 18px;
  position: relative;
  background: none;
  border: none;
  cursor: pointer;
}
.sp-nav-btn:hover {
  background: rgba(185, 119, 52, 0.08);
  color: var(--sp-primary);
}
.sp-cart-badge {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 16px;
  height: 16px;
  background: var(--sp-primary);
  color: #fff;
  font-size: 10px;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sp-mobile-menu-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 9997; /* Between navbar and scroll progress */
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}
.sp-mobile-menu-overlay.active {
  opacity: 1;
  visibility: visible;
}
.sp-mobile-nav {
  position: fixed;
  top: 0;
  right: 0;
  width: 300px;
  max-width: 100%;
  height: 100%;
  background: var(--sp-bg);
  z-index: 9998; /* Same as navbar */
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  padding: 24px;
  box-shadow: -10px 0 40px rgba(0,0,0,0.15);
}
.sp-mobile-nav.active {
  transform: translateX(0);
}
.sp-mobile-nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32px;
}
.sp-mobile-nav-header .sp-logo {
  font-size: 18px;
}
.sp-close-btn {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--sp-radius-sm);
  background: none;
  border: none;
  cursor: pointer;
  font-size: 20px;
  color: var(--sp-text-muted);
}
.sp-close-btn:hover {
  background: rgba(185, 119, 52, 0.08);
  color: var(--sp-primary);
}
.sp-mobile-links {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.sp-mobile-link {
  display: block;
  padding: 12px 16px;
  border-radius: var(--sp-radius-sm);
  font-size: 15px;
  font-weight: 500;
  color: var(--sp-text);
  text-decoration: none;
  transition: all 0.2s ease;
}
.sp-mobile-link:hover {
  background: rgba(185, 119, 52, 0.08);
  color: var(--sp-primary);
}

@media (max-width: 900px) {
  .sp-nav-links {
    display: none;
  }
}
@media (min-width: 901px) {
  .sp-hamburger {
    display: none !important;
  }
}
{% endstyle %}

{% assign logo_max_w = section.settings.brand_logo_max_width | default: 35 %}
{% assign logo_max_h = section.settings.brand_logo_max_height | default: 35 %}
{% assign logo_url_w = logo_max_w | times: 2 %} {# Get retina size #}
{% assign logo_style = 'max-width: ' | append: logo_max_w | append: 'px; max-height: ' | append: logo_max_h | append: 'px; width: auto; height: auto;' %}

<div class="sp-header-wrapper">
  <!-- Scroll Progress Bar -->
  <div class="sp-scroll-progress" id="spScrollProgress">
    <div class="sp-scroll-progress-fill"></div>
  </div>

  <!-- Navbar -->
  <header class="sp-navbar" id="spNavbar">
    <div class="sp-nav-container">
      <a href="{{ routes.root_url }}" class="sp-logo">
        {% if section.settings.brand_logo != blank %}
          {{
            section.settings.brand_logo
            | image_url: width: logo_url_w
            | image_tag:
              loading: 'lazy',
              alt: section.settings.brand_logo_alt | default: shop.name,
              class: 'sp-logo-img',
              style: logo_style
          }}
        {% else %}
          Spread <span>Heaven</span>
        {% endif %}
      </a>

      <nav class="sp-nav-links">
        {% for block in section.blocks %}
          {% if block.type == 'nav_link' %}
            <a href="{{ block.settings.link }}" class="sp-nav-link {% if block.settings.active %}active{% endif %}">
              {{ block.settings.label | escape }}
            </a>
          {% endif %}
        {% endfor %}
      </nav>

      <div class="sp-nav-actions">
        {% if section.settings.show_theme_toggle %}
          <button class="sp-nav-btn" id="spThemeToggle" title="Toggle Theme" aria-label="Toggle dark mode">
            <i class="fa-solid fa-moon"></i>
          </button>
        {% endif %}
        
        <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="sp-nav-btn" title="Account" aria-label="Account">
          <i class="fa-solid fa-user"></i>
        </a>
        
        <button class="sp-nav-btn" data-open-cart="true" title="Open Cart" aria-label="Open cart">
          <i class="fa-solid fa-bag-shopping"></i>
          {% if cart.item_count > 0 %}
            <span class="sp-cart-badge">{{ cart.item_count }}</span>
          {% endif %}
        </button>
        
        <button class="sp-nav-btn sp-hamburger" id="spMenuToggle" title="Open Menu" aria-label="Open menu">
          <i class="fa-solid fa-bars"></i>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile Menu Overlay -->
  <div class="sp-mobile-menu-overlay" id="spMenuOverlay"></div>

  <!-- Mobile Navigation -->
  <div class="sp-mobile-nav" id="spMobileNav">
    <div class="sp-mobile-nav-header">
      <a href="{{ routes.root_url }}" class="sp-logo">
        {% if section.settings.brand_logo != blank %}
          {{
            section.settings.brand_logo
            | image_url: width: logo_url_w
            | image_tag:
              loading: 'lazy',
              alt: section.settings.brand_logo_alt | default: shop.name,
              class: 'sp-logo-img',
              style: logo_style
          }}
        {% else %}
          Spread <span>Heaven</span>
        {% endif %}
      </a>
      <button class="sp-close-btn" id="spCloseMenu" aria-label="Close menu">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <div class="sp-mobile-links">
      {% for block in section.blocks %}
        {% if block.type == 'nav_link' %}
          <a href="{{ block.settings.link }}" class="sp-mobile-link">
            {{ block.settings.label | escape }}
          </a>
        {% endif %}
      {% endfor %}
      
      <div style="margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--sp-border);">
        {% if customer %}
          <a href="{{ routes.account_url }}" class="sp-mobile-link">
            <i class="fa-solid fa-user" style="margin-right: 12px;"></i> My Account
          </a>
          <a href="{{ routes.account_logout_url }}" class="sp-mobile-link">
            <i class="fa-solid fa-right-from-bracket" style="margin-right: 12px;"></i> Logout
          </a>
        {% else %}
          <a href="{{ routes.account_login_url }}" class="sp-mobile-link">
            <i class="fa-solid fa-right-to-bracket" style="margin-right: 12px;"></i> Login
          </a>
          <a href="{{ routes.account_register_url }}" class="sp-mobile-link">
            <i class="fa-solid fa-user-plus" style="margin-right: 12px;"></i> Register
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  <!-- Cart Drawer -->
  {% render 'spread-heaven-cart-drawer' %}
</div>

<script>
(function() {
  // DOM Elements
  const scrollProgress = document.getElementById('spScrollProgress');
  const navbar = document.getElementById('spNavbar');
  const menuToggle = document.getElementById('spMenuToggle');
  const mobileNav = document.getElementById('spMobileNav');
  const menuOverlay = document.getElementById('spMenuOverlay');
  const closeMenuBtn = document.getElementById('spCloseMenu');
  
  // Scroll Progress + Navbar Effect
  function updateScrollProgress() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = (scrollTop / docHeight) * 100;
    document.documentElement.style.setProperty('--sp-scroll-progress', progress + '%');
    
    // Navbar scrolled state
    if (scrollTop > 10) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  }
  
  // Mobile Menu
  function openMobileMenu() {
    mobileNav.classList.add('active');
    menuOverlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  
  function closeMobileMenu() {
    mobileNav.classList.remove('active');
    menuOverlay.classList.remove('active');
    document.body.style.overflow = '';
  }
  
  // Event Listeners
  window.addEventListener('scroll', updateScrollProgress);
  window.addEventListener('load', updateScrollProgress);
  
  if (menuToggle) {
    menuToggle.addEventListener('click', openMobileMenu);
  }
  if (closeMenuBtn) {
    closeMenuBtn.addEventListener('click', closeMobileMenu);
  }
  if (menuOverlay) {
    menuOverlay.addEventListener('click', closeMobileMenu);
  }
})();
</script>

{% schema %}
{
  "name": "Spread Heaven Header",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
